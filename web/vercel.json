{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/generate-bills",
      "schedule": "0 2 15 1 *"
    },
    {
      "path": "/api/cron/generate-bills",
      "schedule": "0 2 15 2 *"
    }
  ]
}